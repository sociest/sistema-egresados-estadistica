# ══════════════════════════════════════════════════════════
#  .env.production.example
#  Sistema de Seguimiento de Egresados — Estadística UMSA
#  Copia este archivo como .env.production y completa los valores
# ══════════════════════════════════════════════════════════

# ── Base de datos ─────────────────────────────────────────
# La contraseña de PostgreSQL. El servicio "db" en docker-compose la usa.
DB_PASSWORD=cambia_esto_por_una_contraseña_segura

# URL completa de conexión (el host es "db" porque es el nombre del servicio Docker)
DATABASE_URL=postgresql://postgres:cambia_esto_por_una_contraseña_segura@db:5432/egresados_db

# ── Opciones Avanzadas ────────────────────────────────────
# Actívalo solo si estás probando en HTTP sin SSL (ej. por IP)
# DISABLE_SECURE_COOKIES=true

# ── JWT ───────────────────────────────────────────────────
# Genera uno seguro con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=cambia_esto_por_un_secreto_seguro_de_al_menos_32_caracteres

# ── Entorno ───────────────────────────────────────────────
NODE_ENV=production

# URL pública donde estará desplegada la app (sin / al final)
NEXTAUTH_URL=https://tudominio.bo

# ── Correo (Nodemailer) ───────────────────────────────────
# Si usas Gmail con contraseña de aplicación:
EMAIL_USER=tu_correo@gmail.com
EMAIL_PASS=tu_contraseña_de_aplicacion_gmail
EMAIL_FROM="Sistema Egresados Estadística <tu_correo@gmail.com>"

# ── Admin inicial (solo para el seed) ────────────────────
ADMIN_EMAIL=admin@estadistica.bo
ADMIN_PASSWORD=CambiaEstoEnProduccion123!

# ── Futuro: SMS (Twilio) ──────────────────────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_PHONE_NUMBER=+1234567890

# ── Cloudflare Turnstile ──────────────────────────────────
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=tu_site_key
# TURNSTILE_SECRET=tu_secret_key
# TURNSTILE_BYPASS=false